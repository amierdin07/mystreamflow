<% layout('layout') -%>

<div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold flex items-center gap-2">
      <i class="ti ti-bolt text-primary"></i>
      <span>Autolive Series</span>
    </h2>
    <p class="text-gray-400 text-sm mt-1">Jadwalkan siaran rutin dengan rotasi judul dan thumbnail otomatis</p>
  </div>
  <% if (youtubeConnected) { %>
  <button onclick="openCreateSeriesModal()" class="w-full md:w-auto flex items-center justify-center gap-2 bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors">
    <i class="ti ti-plus"></i>
    <span>Buat Autolive Baru</span>
  </button>
  <% } %>
</div>

<% if (!youtubeConnected) { %>
<div class="bg-yellow-900/20 border border-yellow-600/30 rounded-lg p-6 mb-6">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 bg-yellow-500/20 rounded-full flex items-center justify-center flex-shrink-0">
      <i class="ti ti-brand-youtube text-yellow-400 text-2xl"></i>
    </div>
    <div>
      <h3 class="text-lg font-medium text-yellow-200">YouTube Connection Required</h3>
      <p class="text-yellow-300/80 mt-1">To use Autolive, you need to connect your YouTube account first.</p>
      <a href="/settings?activeTab=integration" class="inline-flex items-center gap-2 mt-3 px-4 py-2 bg-yellow-600 hover:bg-yellow-500 text-white rounded-lg transition-colors">
        <i class="ti ti-plug"></i>
        <span>Connect YouTube</span>
      </a>
    </div>
  </div>
</div>
<% } else { %>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" id="series-grid">
  <% if (series && series.length > 0) { %>
    <% series.forEach(item => { %>
      <div class="bg-dark-800 border border-gray-700/50 rounded-xl overflow-hidden hover:border-primary/50 transition-all group" data-series-id="<%= item.id %>">
        <div class="p-5">
          <div class="flex justify-between items-start mb-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                <i class="ti ti-bolt text-xl"></i>
              </div>
              <div>
                <h3 class="font-bold text-white group-hover:text-primary transition-colors"><%= item.name %></h3>
                <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="text-[9px] bg-dark-900 text-gray-400 px-1.5 py-0.5 rounded border border-gray-700/50 flex items-center gap-1">
                        <i class="ti ti-<%= item.internal_playlist_id ? 'list-details' : 'video' %> text-[10px]"></i>
                        <span class="max-w-[100px] truncate"><%= item.internal_playlist_id ? item.internal_playlist_name : item.video_title %></span>
                    </span>
                    <span class="text-[9px] text-primary font-bold bg-primary/10 px-1.5 py-0.5 rounded border border-primary/20">
                        <%= item.current_item_index + 1 %> / <%= item.item_count %>
                    </span>
                    <% if (item.status === 'live' && item.current_item_title) { %>
                        <div class="w-full mt-1.5 text-[10px] text-green-400 font-medium flex items-center gap-1">
                            <i class="ti ti-typography"></i>
                            <span class="truncate italic">"<%= item.current_item_title %>"</span>
                        </div>
                    <% } %>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="editSeries('<%= item.id %>')" class="p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded-lg transition-all" title="Edit">
                <i class="ti ti-edit"></i>
              </button>
              <button onclick="deleteSeries('<%= item.id %>')" class="p-2 text-gray-400 hover:text-red-500 hover:bg-red-500/10 rounded-lg transition-all" title="Delete">
                <i class="ti ti-trash"></i>
              </button>
            </div>
          </div>

          <div class="space-y-3">
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-400">Status</span>
              <div class="flex items-center gap-2">
                <% if (item.status === 'live') { %>
                  <span class="flex items-center text-green-400 text-xs font-bold uppercase tracking-wider">
                    <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse mr-1.5"></span>
                    LIVE NOW
                  </span>
                <% } else if (item.is_active) { %>
                  <span class="text-blue-400 text-xs font-bold uppercase tracking-wider">SCHEDULED</span>
                <% } else { %>
                  <span class="text-gray-500 text-xs font-bold uppercase tracking-wider">INACTIVE</span>
                <% } %>
                
                <label class="relative inline-flex items-center cursor-pointer ml-2">
                  <input type="checkbox" value="" class="sr-only peer" <%= item.is_active ? 'checked' : '' %> onchange="toggleSeries('<%= item.id %>')">
                  <div class="w-9 h-5 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
                </label>
              </div>
            </div>

            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-400">YouTube Settings</span>
              <div class="flex items-center gap-2">
                <span class="text-xs <%= item.privacy === 'public' ? 'text-green-400' : 'text-gray-400' %> uppercase"><%= item.privacy %></span>
                <% if (item.monetization_enabled) { %>
                  <i class="ti ti-currency-dollar text-green-500" title="Monetization Enabled"></i>
                <% } %>
              </div>
            </div>

            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-400">Jadwal</span>
              <span class="text-white font-medium flex items-center gap-1.5">
                <i class="ti ti-calendar-event text-gray-500"></i>
                <%= item.repeat_mode === 'none' ? 'Sekali Saja' : item.repeat_mode.charAt(0).toUpperCase() + item.repeat_mode.slice(1) %>
              </span>
            </div>

            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-400">Mulai Berikutnya</span>
              <span class="text-amber-400 font-mono text-xs">
                <%= helpers.formatDateTime(item.start_time) %>
              </span>
            </div>
          </div>
        </div>
        
        <div class="bg-dark-900/50 px-5 py-3 border-t border-gray-700/50 flex items-center justify-between">
            <a href="<%= item.youtube_broadcast_id ? `https://studio.youtube.com/video/${item.youtube_broadcast_id}/livestreaming` : 'https://studio.youtube.com' %>" target="_blank" class="flex items-center gap-2 text-xs text-gray-400 hover:text-primary transition-colors group">
                <i class="ti ti-brand-youtube text-red-500 group-hover:scale-110 transition-transform"></i>
                <span class="truncate max-w-[150px] font-medium"><%= item.youtube_channel_name || 'No Channel' %></span>
                <i class="ti ti-external-link text-[10px] opacity-0 group-hover:opacity-100 transition-opacity"></i>
            </a>
            <div class="text-[10px] text-gray-500 uppercase tracking-tighter">
                ID: <%= item.id.substring(0, 8) %>
            </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-span-full py-20 flex flex-col items-center justify-center bg-dark-800 rounded-2xl border-2 border-dashed border-gray-700">
      <div class="w-20 h-20 bg-gray-700/30 rounded-full flex items-center justify-center mb-4">
        <i class="ti ti-bolt-off text-4xl text-gray-500"></i>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Belum ada Autolive</h3>
      <p class="text-gray-400 text-center max-w-sm mb-6">Mulai otomatisasi siaran rutin kamu dengan klik tombol di bawah.</p>
      <button onclick="openCreateSeriesModal()" class="flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-6 py-3 rounded-xl transition-all shadow-lg shadow-primary/20">
        <i class="ti ti-plus"></i>
        <span>Buat Autolive Pertama</span>
      </button>
    </div>
  <% } %>
</div>

<% } %>

<!-- Create/Edit Modal -->
<div id="autoliveModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
    <div class="bg-dark-800 w-full max-w-4xl max-h-[90vh] rounded-2xl shadow-2xl border border-gray-700 overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-gray-700 flex items-center justify-between flex-shrink-0">
            <h3 class="text-xl font-bold flex items-center gap-2" id="modalTitle">
                <i class="ti ti-bolt text-primary"></i>
                <span>Buat Autolive Baru</span>
            </h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-white transition-colors p-2 hover:bg-gray-700 rounded-lg">
                <i class="ti ti-x text-2xl"></i>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto p-6 custom-scrollbar">
            <form id="autoliveForm" class="space-y-8">
                <input type="hidden" id="seriesId">
                
                <!-- Section 1: Basic Config -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Nama Seri</label>
                            <input type="text" id="seriesName" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="Contoh: Monday Music Live">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Pilih Playlist (Internal) - <span class="text-primary font-bold">UTAMA</span></label>
                            <select id="internalPlaylistId" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all border-primary/30">
                                <option value="">-- Gunakan Single Video Saja --</option>
                                <% playlists.forEach(p => { %>
                                    <option value="<%= p.id %>"><%= p.name %></option>
                                <% }) %>
                            </select>
                            <p class="text-[10px] text-gray-500 mt-1">Gunakan ini jika ingin memutar banyak video dari playlist.</p>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Atau Pilih Video (Single)</label>
                            <select id="videoId" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                                <option value="">-- Pilih Video --</option>
                                <% videos.forEach(v => { %>
                                    <option value="<%= v.id %>"><%= v.title %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">YouTube Channel</label>
                            <select id="channelId" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                                <% youtubeChannels.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.channel_name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Waktu Mulai Pertama</label>
                            <input type="datetime-local" id="startTime" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Pengulangan</label>
                                <select id="repeatMode" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                                    <option value="none">Sekali Saja</option>
                                    <option value="daily">Setiap Hari</option>
                                    <option value="weekly">Setiap Minggu (Weekly)</option>
                                    <option value="monday">Setiap Senin</option>
                                    <option value="tuesday">Setiap Selasa</option>
                                    <option value="wednesday">Setiap Rabu</option>
                                    <option value="thursday">Setiap Kamis</option>
                                    <option value="friday">Setiap Jumat</option>
                                    <option value="saturday">Setiap Sabtu</option>
                                    <option value="sunday">Setiap Minggu (Hari)</option>
                                    <option value="every_2_days">Setiap 2 Hari</option>
                                    <option value="every_3_days">Setiap 3 Hari</option>
                                    <option value="every_4_days">Setiap 4 Hari</option>
                                    <option value="every_5_days">Setiap 5 Hari</option>
                                    <option value="custom">Pilih Tanggal Spesifik</option>
                                </select>
                            </div>

                            <div id="customDatesContainer" class="col-span-2 hidden bg-dark-900/50 p-4 rounded-xl border border-primary/20 mb-4">
                                <label class="block text-sm font-medium text-primary mb-2 flex items-center gap-2">
                                    <i class="ti ti-calendar-plus"></i>
                                    <span>Pilih Tanggal-Tanggal Live</span>
                                </label>
                                <div class="flex gap-2 mb-3">
                                    <div class="relative flex-1">
                                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">
                                            <i class="ti ti-calendar"></i>
                                        </div>
                                        <input type="date" id="datePicker" onclick="this.showPicker()" class="w-full bg-dark-800 border border-gray-700 rounded-xl pl-10 pr-4 py-3 text-white text-sm focus:ring-2 focus:ring-primary focus:border-transparent transition-all cursor-pointer">
                                    </div>
                                    <button type="button" onclick="addCustomDate()" class="bg-primary hover:bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all flex items-center gap-2 shadow-lg shadow-primary/20">
                                        <i class="ti ti-plus"></i> Tambah
                                    </button>
                                </div>
                                <div id="customDatesList" class="flex flex-wrap gap-2 min-h-[40px] p-2 bg-dark-800/50 rounded-xl border border-gray-700/50">
                                    <span class="text-xs text-gray-500 italic w-full text-center py-1" id="noDatesHint">Belum ada tanggal dipilih</span>
                                </div>
                            </div>
                            <div class="col-span-2">
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Durasi Live</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="relative">
                                        <input type="number" id="durationHours" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all pr-10" placeholder="0" value="4">
                                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 text-xs">Jam</span>
                                    </div>
                                    <div class="relative">
                                        <input type="number" id="durationMinutes" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all pr-12" placeholder="0" value="0">
                                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 text-xs">Menit</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="h-px bg-gray-700 my-8"></div>

                <!-- Section 1.5: YouTube Advanced Settings -->
                <div class="space-y-6">
                    <h4 class="text-lg font-bold flex items-center gap-2">
                        <i class="ti ti-brand-youtube text-red-500"></i>
                        <span>YouTube Advanced Settings</span>
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 bg-dark-900/30 p-6 rounded-2xl border border-gray-700/50">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Privacy</label>
                            <select id="privacy" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                                <option value="public" selected>Public</option>
                                <option value="unlisted">Unlisted</option>
                                <option value="private">Private</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Kategori (Genre)</label>
                            <select id="categoryId" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                                <option value="10" selected>Music</option>
                                <option value="20">Gaming</option>
                                <option value="24">Entertainment</option>
                                <option value="22">People & Blogs</option>
                                <option value="27">Education</option>
                                <option value="1">Film & Animation</option>
                                <option value="2">Autos & Vehicles</option>
                                <option value="15">Pets & Animals</option>
                                <option value="17">Sports</option>
                                <option value="19">Travel & Events</option>
                                <option value="23">Comedy</option>
                                <option value="25">News & Politics</option>
                                <option value="26">Howto & Style</option>
                                <option value="28">Science & Technology</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Monetisasi & Kids</label>
                            <div class="space-y-2 mt-2">
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="checkbox" id="monetizationEnabled" class="w-4 h-4 rounded border-gray-700 bg-dark-900 text-primary focus:ring-primary" checked>
                                    <span class="text-sm text-gray-300 group-hover:text-white transition-colors">Aktifkan Iklan</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="checkbox" id="madeForKids" class="w-4 h-4 rounded border-gray-700 bg-dark-900 text-primary focus:ring-primary">
                                    <span class="text-sm text-gray-300 group-hover:text-white transition-colors">Dibuat untuk Anak</span>
                                </label>
                            </div>
                        </div>

                        <div class="md:col-span-3">
                            <label class="block text-sm font-medium text-gray-400 mb-1.5">Pilih Playlist YouTube (Opsional)</label>
                            <select id="playlistId" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
                                <option value="">-- Tanpa Playlist --</option>
                            </select>
                            <p class="text-[10px] text-gray-500 mt-1" id="playlistHint">Pilih channel terlebih dahulu untuk memuat playlist.</p>
                        </div>
                    </div>
                </div>

                <div class="h-px bg-gray-700 my-8"></div>

                <!-- Section 2: Bulk Metadata -->
                <div class="space-y-6">
                    <div class="flex items-center justify-between">
                        <h4 class="text-lg font-bold flex items-center gap-2">
                            <i class="ti ti-list-details text-primary"></i>
                            <span>Rotasi Metadata (Judul & Thumbnail)</span>
                        </h4>
                        <span class="text-xs bg-primary/10 text-primary px-2 py-1 rounded">Auto-Swap 24 Jam Aktif</span>
                    </div>

                    <div class="bg-dark-900/50 p-6 rounded-2xl border border-gray-700/50 space-y-6">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Daftar Judul (Satu per baris)</label>
                                <textarea id="bulkTitles" rows="6" class="w-full bg-dark-900 border border-gray-700 rounded-xl px-4 py-3 text-white font-mono text-sm focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="Judul Episode 1&#10;Judul Episode 2&#10;Judul Episode 3..."></textarea>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-400 mb-1.5">Upload Thumbnail (Banyak file)</label>
                                <div class="relative group h-[158px]">
                                    <input type="file" id="bulkThumbnails" multiple accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="handleThumbnailPreview(this)">
                                    <div class="w-full h-full border-2 border-dashed border-gray-700 rounded-xl flex flex-col items-center justify-center group-hover:border-primary transition-all bg-dark-900/30">
                                        <i class="ti ti-photo-plus text-3xl text-gray-500 mb-2 group-hover:text-primary transition-colors"></i>
                                        <p class="text-sm text-gray-400">Klik atau seret gambar ke sini</p>
                                        <p class="text-xs text-gray-500 mt-1" id="thumbCount">Belum ada file dipilih</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <button type="button" onclick="generateItemsFromBulk()" class="w-full py-3 bg-gray-700 hover:bg-gray-600 text-white rounded-xl font-bold transition-all flex items-center justify-center gap-2">
                            <i class="ti ti-refresh"></i>
                            <span>Generate List Metadata</span>
                        </button>
                    </div>

                    <div id="itemsPreview" class="space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                        <!-- Generated items will appear here -->
                    </div>
                </div>
            </form>
        </div>

        <div class="px-6 py-4 border-t border-gray-700 flex items-center justify-end gap-3 flex-shrink-0 bg-dark-800/80 backdrop-blur-md">
            <button onclick="closeModal()" class="px-6 py-2.5 text-gray-400 hover:text-white transition-colors font-medium">Batal</button>
            <button onclick="saveSeries()" id="saveBtn" class="px-8 py-2.5 bg-primary hover:bg-blue-600 text-white rounded-xl font-bold transition-all shadow-lg shadow-primary/20 flex items-center gap-2">
                <i class="ti ti-device-floppy"></i>
                <span>Simpan Autolive</span>
            </button>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #4B5563; }
</style>

<script>
    let currentItems = [];
    let selectedDates = [];

    document.getElementById('repeatMode').addEventListener('change', function() {
        const container = document.getElementById('customDatesContainer');
        if (this.value === 'custom') {
            container.classList.remove('hidden');
        } else {
            container.classList.add('hidden');
        }
    });

    document.getElementById('channelId').addEventListener('change', function() {
        loadPlaylists(this.value);
    });

    async function loadPlaylists(channelId, selectedPlaylistId = '') {
        const select = document.getElementById('playlistId');
        const hint = document.getElementById('playlistHint');
        
        if (!channelId) {
            select.innerHTML = '<option value="">-- Tanpa Playlist --</option>';
            hint.innerText = 'Pilih channel terlebih dahulu untuk memuat playlist.';
            return;
        }

        hint.innerText = 'Memuat playlist...';
        select.disabled = true;

        try {
            const response = await fetch(`/api/youtube/playlists/${channelId}`);
            const result = await response.json();
            
            if (result.success) {
                select.innerHTML = '<option value="">-- Tanpa Playlist --</option>';
                result.playlists.forEach(p => {
                    const option = document.createElement('option');
                    option.value = p.id;
                    option.text = p.title;
                    if (p.id === selectedPlaylistId) option.selected = true;
                    select.appendChild(option);
                });
                hint.innerText = `Berhasil memuat ${result.playlists.length} playlist.`;
            } else {
                hint.innerText = 'Gagal memuat playlist.';
            }
        } catch (e) {
            console.error('Error fetching playlists:', e);
            hint.innerText = 'Gagal memuat playlist.';
        } finally {
            select.disabled = false;
        }
    }

    function addCustomDate() {
        const picker = document.getElementById('datePicker');
        const date = picker.value;
        if (!date) return;
        
        if (selectedDates.includes(date)) return;
        
        selectedDates.push(date);
        selectedDates.sort();
        renderCustomDates();
        picker.value = '';
    }

    function removeCustomDate(date) {
        selectedDates = selectedDates.filter(d => d !== date);
        renderCustomDates();
    }

    function renderCustomDates() {
        const container = document.getElementById('customDatesList');
        container.innerHTML = '';
        
        if (selectedDates.length === 0) {
            container.innerHTML = '<span class="text-xs text-gray-500 italic w-full text-center py-1" id="noDatesHint">Belum ada tanggal dipilih</span>';
            return;
        }
        
        selectedDates.forEach(date => {
            const badge = document.createElement('div');
            badge.className = 'flex items-center gap-2 bg-primary/20 text-primary border border-primary/30 px-2 py-1 rounded-lg text-xs font-medium';
            badge.innerHTML = `
                <span>${date}</span>
                <button type="button" onclick="removeCustomDate('${date}')" class="hover:text-white">
                    <i class="ti ti-x"></i>
                </button>
            `;
            container.appendChild(badge);
        });
    }

    function openCreateSeriesModal() {
        document.getElementById('seriesName').value = '';
        document.getElementById('videoId').value = '';
        document.getElementById('internalPlaylistId').value = '';
        document.getElementById('startTime').value = '';
        document.getElementById('itemsPreview').innerHTML = '';
        document.getElementById('customDatesContainer').classList.add('hidden');
        document.getElementById('customDatesList').innerHTML = '';
        
        // Reset YouTube settings to defaults
        document.getElementById('privacy').value = 'public';
        document.getElementById('categoryId').value = '10';
        document.getElementById('monetizationEnabled').checked = true;
        document.getElementById('madeForKids').checked = false;
        document.getElementById('playlistId').innerHTML = '<option value="">-- Tanpa Playlist --</option>';

        // Load playlists for initial channel
        const initialChannelId = document.getElementById('channelId').value;
        if (initialChannelId) loadPlaylists(initialChannelId);

        currentItems = [];
        selectedDates = [];
        document.getElementById('autoliveModal').classList.remove('hidden');
        document.getElementById('autoliveModal').classList.add('flex');
    }

    function closeModal() {
        document.getElementById('autoliveModal').classList.add('hidden');
        document.getElementById('autoliveModal').classList.remove('flex');
    }

    function handleThumbnailPreview(input) {
        const count = input.files.length;
        document.getElementById('thumbCount').innerText = `${count} file dipilih`;
    }

    function generateItemsFromBulk() {
        const titlesText = document.getElementById('bulkTitles').value.trim();
        if (!titlesText) {
            alert('Masukkan daftar judul terlebih dahulu');
            return;
        }

        const titles = titlesText.split('\n').map(t => t.trim()).filter(t => t);
        const thumbnailFiles = document.getElementById('bulkThumbnails').files;
        
        currentItems = titles.map((title, index) => {
            return {
                title: title,
                description: '',
                tags: '',
                thumbnail_file: thumbnailFiles[index % thumbnailFiles.length] || null,
                thumbnail_upload_index: thumbnailFiles.length > 0 ? (index % thumbnailFiles.length) : -1
            };
        });

        renderItemsPreview();
    }

    function renderItemsPreview() {
        const container = document.getElementById('itemsPreview');
        container.innerHTML = '';

        if (currentItems.length === 0) return;

        currentItems.forEach((item, index) => {
            const div = document.createElement('div');
            div.className = 'flex items-center gap-4 bg-dark-900/50 p-3 rounded-xl border border-gray-700/50';
            div.innerHTML = `
                <div class="w-8 h-8 rounded-full bg-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">
                    ${index + 1}
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-white truncate">${item.title}</div>
                    <div class="text-[10px] text-gray-500 mt-0.5">
                        ${item.thumbnail_file ? `<i class="ti ti-photo mr-1"></i>${item.thumbnail_file.name}` : '<i class="ti ti-photo-off mr-1"></i>No New Thumbnail'}
                    </div>
                </div>
                <button type="button" onclick="removeItem(${index})" class="p-2 text-gray-500 hover:text-red-500 transition-colors">
                    <i class="ti ti-trash"></i>
                </button>
            `;
            container.appendChild(div);
        });
    }

    function removeItem(index) {
        currentItems.splice(index, 1);
        renderItemsPreview();
    }

    async function saveSeries() {
        const btn = document.getElementById('saveBtn');
        const id = document.getElementById('seriesId').value;
        const name = document.getElementById('seriesName').value;
        const internalPlaylistId = document.getElementById('internalPlaylistId').value;
        const startTime = document.getElementById('startTime').value;
        const repeatMode = document.getElementById('repeatMode').value;
        const channelId = document.getElementById('channelId').value;
        
        const hours = parseInt(document.getElementById('durationHours').value) || 0;
        const mins = parseInt(document.getElementById('durationMinutes').value) || 0;
        const duration = (hours * 60) + mins;

        // YouTube Settings
        const privacy = document.getElementById('privacy').value;
        const categoryId = document.getElementById('categoryId').value;
        const monetizationEnabled = document.getElementById('monetizationEnabled').checked ? 1 : 0;
        const madeForKids = document.getElementById('madeForKids').checked ? 1 : 0;
        const playlistId = document.getElementById('playlistId').value;

        if (!name || (!videoId && !internalPlaylistId) || !startTime) {
            alert('Mohon isi semua field wajib (Nama, Video/Playlist, Waktu Mulai)');
            return;
        }

        if (duration <= 0) {
            alert('Durasi live tidak boleh kosong');
            return;
        }

        if (currentItems.length === 0) {
            alert('Mohon tambahkan setidaknya satu judul/metadata');
            return;
        }

        const formData = new FormData();
        formData.append('name', name);
        formData.append('video_id', videoId);
        formData.append('internal_playlist_id', internalPlaylistId);
        formData.append('start_time', startTime);
        formData.append('repeat_mode', repeatMode);
        formData.append('duration', duration);
        formData.append('youtube_channel_id', channelId);
        formData.append('custom_dates', JSON.stringify(selectedDates));
        
        // Add new YouTube fields
        formData.append('privacy', privacy);
        formData.append('category_id', categoryId);
        formData.append('monetization_enabled', monetizationEnabled);
        formData.append('made_for_kids', madeForKids);
        formData.append('playlist_id', playlistId);

        // Add items metadata
        formData.append('items', JSON.stringify(currentItems.map((item, idx) => ({
            title: item.title,
            description: item.description,
            tags: item.tags,
            thumbnail_upload_index: item.thumbnail_upload_index,
            thumbnail_path: item.thumbnail_path, // for edits
            original_thumbnail_path: item.original_thumbnail_path // for edits
        }))));

        // Add actual thumbnail files
        const thumbnailFiles = document.getElementById('bulkThumbnails').files;
        for (let i = 0; i < thumbnailFiles.length; i++) {
            formData.append(`thumbnail_${i}`, thumbnailFiles[i]);
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="ti ti-loader animate-spin"></i><span>Menyimpan...</span>';

        try {
            const url = id ? `/api/autolive/${id}` : '/api/autolive';
            const method = id ? 'PUT' : 'POST';
            
            const response = await fetch(url, {
                method: method,
                body: formData,
                headers: {
                    'x-csrf-token': document.querySelector('input[name="_csrf"]').value
                }
            });

            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Gagal menyimpan: ' + result.error);
                btn.disabled = false;
                btn.innerHTML = '<i class="ti ti-device-floppy"></i><span>Simpan Autolive</span>';
            }
        } catch (error) {
            console.error('Save error:', error);
            alert('Terjadi kesalahan sistem');
            btn.disabled = false;
            btn.innerHTML = '<i class="ti ti-device-floppy"></i><span>Simpan Autolive</span>';
        }
    }

    async function toggleSeries(id) {
        try {
            const response = await fetch(`/api/autolive/${id}/toggle`, {
                method: 'POST',
                headers: { 'x-csrf-token': document.querySelector('input[name="_csrf"]').value }
            });
            const result = await response.json();
            if (!result.success) alert('Gagal mengubah status');
        } catch (e) {
            alert('Terjadi kesalahan');
        }
    }

    async function deleteSeries(id) {
        if (!confirm('Yakin ingin menghapus seri Autolive ini? Semua metadata di dalamnya juga akan terhapus.')) return;

        try {
            const response = await fetch(`/api/autolive/${id}`, {
                method: 'DELETE',
                headers: { 'x-csrf-token': document.querySelector('input[name="_csrf"]').value }
            });
            const result = await response.json();
            if (result.success) location.reload();
        } catch (e) {
            alert('Gagal menghapus');
        }
    }

    async function editSeries(id) {
        try {
            const response = await fetch(`/api/autolive/${id}`);
            const result = await response.json();
            if (!result.success) return alert('Gagal mengambil data');

            const s = result.series;
            document.getElementById('seriesId').value = s.id;
            document.getElementById('seriesName').value = s.name;
            document.getElementById('videoId').value = s.video_id || '';
            document.getElementById('internalPlaylistId').value = s.internal_playlist_id || '';
            document.getElementById('channelId').value = s.youtube_channel_id;
            
            // Format date for datetime-local
            if (s.start_time) {
                const d = new Date(s.start_time);
                const offset = d.getTimezoneOffset() * 60000;
                const localISOTime = (new Date(d - offset)).toISOString().slice(0, 16);
                document.getElementById('startTime').value = localISOTime;
            }
            
            document.getElementById('repeatMode').value = s.repeat_mode;
            if (s.repeat_mode === 'custom') {
                document.getElementById('customDatesContainer').classList.remove('hidden');
                selectedDates = JSON.parse(s.custom_dates || '[]');
                renderCustomDates();
            } else {
                document.getElementById('customDatesContainer').classList.add('hidden');
                selectedDates = [];
                document.getElementById('customDatesList').innerHTML = '';
            }

            document.getElementById('durationHours').value = Math.floor(s.duration / 60);
            document.getElementById('durationMinutes').value = s.duration % 60;
            
            // Set YouTube settings
            document.getElementById('privacy').value = s.privacy || 'public';
            document.getElementById('categoryId').value = s.category_id || '24';
            document.getElementById('monetizationEnabled').checked = s.monetization_enabled === 1;
            document.getElementById('madeForKids').checked = s.made_for_kids === 1;
            
            // Load playlists and select the correct one
            await loadPlaylists(s.youtube_channel_id, s.playlist_id);
            
            currentItems = s.items.map(item => ({
                title: item.title,
                description: item.description,
                tags: item.tags,
                thumbnail_path: item.thumbnail_path,
                original_thumbnail_path: item.original_thumbnail_path,
                thumbnail_upload_index: -1
            }));

            document.getElementById('bulkTitles').value = currentItems.map(i => i.title).join('\n');
            renderItemsPreview();
            
            document.getElementById('modalTitle').innerText = 'Edit Seri Autolive';
            document.getElementById('autoliveModal').classList.remove('hidden');
            document.getElementById('autoliveModal').classList.add('flex');
        } catch (e) {
            alert('Kesalahan saat memuat data');
        }
    }
</script>
